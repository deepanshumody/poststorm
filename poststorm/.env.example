# Copy to .env (repo root) and fill in. .env is gitignored.
CEREBRAS_API_KEY=your-cerebras-key-here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gemma-4-31b

# Optional: GPU baseline for the side-by-side speed race
GEMINI_API_KEY=your-gemini-key-here

# Deployment / security (12-factor; comma-separated allowlist)
CORS_ORIGINS=http://localhost:8000
LOG_LEVEL=INFO
MAX_BATCH=48
